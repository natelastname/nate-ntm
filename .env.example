# Example .env for nate_ntm runtime
#
# Copy this file to `.env` and customize values as needed. The runtime
# will load `.env` automatically when resolving configuration via
# `nate_ntm.config.runtime_config.load_runtime_config`, and the CLI will
# load it on startup. Precedence:
#
#   1. Explicit CLI arguments
#   2. Real environment variables
#   3. Values from this `.env` file
#
# Leave variables commented out if you are happy with the defaults.

# -----------------------------------------------------------------------------
# Core runtime configuration
# -----------------------------------------------------------------------------

# Project directory (used when --project is not provided)
# NATE_NTM_PROJECT_DIR=/absolute/path/to/project

# Metadata directory for nate_ntm state (defaults to <project>/.nate_ntm)
# NATE_NTM_METADATA_DIR=/absolute/path/to/project/.nate_ntm

# Host/interface for the runtime control API (default: 127.0.0.1)
# NATE_NTM_CONTROL_HOST=127.0.0.1

# TCP port for the runtime control API (default: 8765, must be >1024)
# NATE_NTM_CONTROL_PORT=8765

# Logical identifier for the swarm within the project (default: "default")
# NATE_NTM_SWARM_ID=default

# -----------------------------------------------------------------------------
# Adapter selection
# -----------------------------------------------------------------------------

# Global adapter mode; currently supported values:
#   - fake  (in-memory, dev-mode adapters; no external I/O)
#   - real  (production adapters; REAL ACP is not yet implemented)
# NATE_NTM_ADAPTER_MODE=fake

# Override only the Agent Mail adapter kind (defaults to NATE_NTM_ADAPTER_MODE)
# NATE_NTM_AGENT_MAIL_ADAPTER=fake

# Override only the ACP adapter kind (defaults to NATE_NTM_ADAPTER_MODE)
# NATE_NTM_ACP_ADAPTER=fake

# -----------------------------------------------------------------------------
# Agent Mail (MCP-backed) integration
# -----------------------------------------------------------------------------

# Base URL for the MCP Agent Mail HTTP API.
# Used by nate_ntm.runtime.agent_mail_client.McpAgentMailClient.
# NATE_NTM_AGENT_MAIL_URL=http://127.0.0.1:8765/api

# Bearer token for authenticating with the Agent Mail server.
# NATE_NTM_AGENT_MAIL_TOKEN=your-secret-token

# The runtime also honors these alias variables if the NATE_NTM_* forms
# are not set. They are primarily intended for reusing existing Agent
# Mail tooling setups.
# AGENT_MAIL_URL=http://127.0.0.1:8765/api
# AGENT_MAIL_TOKEN=your-secret-token

# -----------------------------------------------------------------------------
# Runtime control API client convenience (CLI)
# -----------------------------------------------------------------------------
# The `nate_ntm api call` subcommand also respects the following when
# invoking the JSON-RPC control API:
#
# NATE_NTM_CONTROL_HOST=127.0.0.1
# NATE_NTM_CONTROL_PORT=8765
